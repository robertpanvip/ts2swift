{
  "name": "ts2swift",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "install-swift": "esno ./installer/index.ts",
    "test": "esno ./src/main.ts",
    "test:vitest": "vitest run",
    "test:import": "esno ./test/ts/imports.ts",
    "ts-swift": "esno ts-swift.ts",
    "run-basic": "npm run ts-swift ./test/ts/basic.ts",
    "run-complex": "npm run ts-swift ./test/ts/complex.ts",
    "run-module": "npm run ts-swift ./test/ts/module.ts",
    "run-util": "npm run ts-swift ./test/ts/util.ts",
    "run-arrays": "npm run ts-swift ./test/ts/arrays.ts",
    "run-objects": "npm run ts-swift ./test/ts/objects.ts",
    "run-functions": "npm run ts-swift ./test/ts/functions.ts",
    "run-types": "npm run ts-swift ./test/ts/types.ts",
    "run-classes": "npm run ts-swift ./test/ts/classes.ts",
    "run-async": "npm run ts-swift ./test/ts/async.ts",
    "run-strings": "npm run ts-swift ./test/ts/strings.ts",
    "run-control-flow": "npm run ts-swift ./test/ts/control-flow.ts",
    "run-concat": "npm run ts-swift ./test/ts/concat.ts",
    "run-object-props": "npm run ts-swift ./test/ts/object-props.ts",
    "run-enum": "npm run ts-swift ./test/ts/enum.ts",
    "run-interface": "npm run ts-swift ./test/ts/interface.ts",
    "run-generics": "npm run ts-swift ./test/ts/generics.ts",
    "run-exports": "npm run ts-swift ./test/ts/exports.ts",
    "run-imports": "npm run ts-swift ./test/ts/imports.ts ./test/ts/exports.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "~5.7.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "esno": "^4.8.0",
    "ts-morph": "^25.0.1"
  }
}
